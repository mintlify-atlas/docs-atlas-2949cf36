  "keyFeatures": [
    "TypeScript-configured uptime monitoring with configurable intervals and cron schedules",
    "Public status pages with RSS and Atom feeds",
    "Smart alerting with flap detection, auto-resolve, and webhook notifications",
    "Multi-region monitoring with region-aware alert thresholds",
    "S3 archival to Parquet with day-based partitioning",
    "Response time charts, uptime bars, and latency percentiles",
    "SLA tracking and status distribution",
    "Incident timelines and announcements"
  ],
  "publicApiSurface": [
    "monitor() - Define uptime monitors with handlers",
    "channels() - Configure webhook notification channels",
    "DashboardConfig - Dashboard configuration interface",
    "AlertConfig - Alert configuration with conditions",
    "MonitorResult - Monitor handler return type",
    "DeclarativeCondition - Alert condition types",
    "WebhookPayload - Webhook notification payload",
    "Scheduler HTTP API - /health, /monitors, /monitors/:id/trigger",
    "Dashboard routes - /, /monitors, /alerts, /dashboards, /shared/[slug]",
    "RSS/Atom feeds - /shared/[slug]/feed.xml, /shared/[slug]/feed.atom"
  ]
